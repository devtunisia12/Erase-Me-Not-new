height, emissive) to 3D objects","version":"1.2.0","description":"Apply PBR texture maps (albedo/diffuse, normal, roughness, metalness, ambient occlusion, displacement/height and emissive) to 3D cubes and models. Supports PNG and WebP formats.","origin":{"identifier":"PBRMaps3D","name":"gdevelop-extension-store"},"tags":["3d","pbr","normal","ao","ambient-occlusion","height","displacement","emissive","roughness","metalness","albedo","diffuse","map","texture"],"authorIds":["NuVWggGWyqcoSz9wvk7H8B2J44q1"],"dependencies":[],"globalVariables":[],"sceneVariables":[],"eventsFunctions":[{"description":"Apply a normal map to add realistic surface details like bumps and texture. Works with 3D cubes, models, and animated models.","fullName":"Set Normal Map","functionType":"Action","name":"SetNormalMap","sentence":"Set normal map of _PARAM1_ to _PARAM2_ with scale _PARAM3_ and intensity _PARAM4_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","var imageName = eventsFunctionContext.getArgument(\"NormalMap\");","var scaleVal = Number(eventsFunctionContext.getArgument(\"Scale\"));","var intensityVal = Number(eventsFunctionContext.getArgument(\"Intensity\"));","","if (isNaN(scaleVal) || scaleVal <= 0) scaleVal = 1;","if (isNaN(intensityVal)) intensityVal = 1;","","var game = runtimeScene.getGame();","var imageUrl = imageName;","try {","    var res = game.getResourcesManager();","    if (res && res.getResource(imageName)) {","        imageUrl = res.getResource(imageName).getFile();","    }","} catch(e) {}","","var capturedScale = scaleVal;","var capturedIntensity = intensityVal;","var capturedObjs = objs.slice();","var loader = new THREE.TextureLoader();","loader.load(imageUrl, function(tex) {","    tex.wrapS = THREE.RepeatWrapping;","    tex.wrapT = THREE.RepeatWrapping;","    if (typeof tex.encoding !== 'undefined') {","        tex.encoding = THREE.LinearEncoding;","    } else if (typeof tex.colorSpace !== 'undefined') {","        tex.colorSpace = THREE.NoColorSpace;","    }","    ","    for (var i = 0; i < capturedObjs.length; i++) {","        if (!capturedObjs[i].get3DRendererObject) continue;","        var root = capturedObjs[i].get3DRendererObject();","        if (!root) continue;","        ","        var objType = capturedObjs[i].getType ? capturedObjs[i].getType() : '';","        var isGLB = objType.indexOf('Model3D') !== -1 || objType.indexOf('Scene3D::Model3DObject') !== -1;","        ","        root.traverse(function(c) {","            if (!c.isMesh || !c.material) return;","            ","            var materials = Array.isArray(c.material) ? c.material : [c.material];","            var newMaterials = [];","            ","            for (var m = 0; m < materials.length; m++) {","                var mat = materials[m];","                ","                if (mat.isMeshBasicMaterial) {","                    mat = new THREE.MeshStandardMaterial({","                        color: mat.color ? mat.color.clone() : new THREE.Color(0xffffff),","                        map: mat.map || null,","                        transparent: mat.transparent,","                        opacity: mat.opacity !== undefined ? mat.opacity : 1,","                        side: mat.side !== undefined ? mat.side : THREE.FrontSide,","                        metalness: 0.0,","                        roughness: 0.7,","                        skinning: mat.skinning === true,","                        morphTargets: mat.morphTargets === true,","                        morphNormals: mat.morphNormals === true","                    });","                } else if (!c.userData._normalMapApplied) {","                    mat = mat.clone();","                }","                ","                if (mat.isMeshStandardMaterial || mat.isMeshPhongMaterial || mat.isMeshPhysicalMaterial) {","                    var clonedTex = tex.clone();","                    clonedTex.wrapS = THREE.RepeatWrapping;","                    clonedTex.wrapT = THREE.RepeatWrapping;","                    if (typeof clonedTex.encoding !== 'undefined') {","                        clonedTex.encoding = THREE.LinearEncoding;","                    } else if (typeof clonedTex.colorSpace !== 'undefined') {","                        clonedTex.colorSpace = THREE.NoColorSpace;","                    }","                    clonedTex.flipY = !isGLB;","                    clonedTex.repeat.set(capturedScale, capturedScale);","                    clonedTex.needsUpdate = true;","                    ","                    mat.normalMap = clonedTex;","                    mat.normalMapType = THREE.TangentSpaceNormalMap;","                    ","                    if (mat.normalScale && mat.normalScale.isVector2) {","                        mat.normalScale.set(capturedIntensity, capturedIntensity);","                    } else {","                        mat.normalScale = new THREE.Vector2(capturedIntensity, capturedIntensity);","                    }","                    ","                    mat.needsUpdate = true;","                }","                ","                newMaterials.push(mat);","            }","            ","            c.material = Array.isArray(c.material) ? newMaterials : newMaterials[0];","            c.userData._normalMapApplied = true;","        });","    }","});"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to apply the normal map to","name":"Object","type":"objectList"},{"description":"The normal map image (purple/blue texture). PNG or WebP recommended.","name":"NormalMap","type":"imageResource"},{"description":"How many times the texture repeats. 1 = no repeat, 2 = repeats 2x, 0.5 = stretched","name":"Scale","type":"expression"},{"description":"Intensity/strength of the normal map effect. 1 = normal, 0 = no effect, 2 = double strength","name":"Intensity","type":"expression"}],"objectGroups":[]},{"description":"Remove normal map from a 3D object.","fullName":"Remove Normal Map","functionType":"Action","name":"RemoveNormalMap","sentence":"Remove normal map from _PARAM1_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","for (var i = 0; i < objs.length; i++) {","    if (!objs[i].get3DRendererObject) continue;","    var root = objs[i].get3DRendererObject();","    if (!root) continue;","    root.traverse(function(c) {","        if (!c.isMesh || !c.material) return;","        var materials = Array.isArray(c.material) ? c.material : [c.material];","        for (var m = 0; m < materials.length; m++) {","            if (materials[m] && materials[m].normalMap) {","                materials[m].normalMap = null;","                materials[m].needsUpdate = true;","            }","        }","    });","}"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to remove normal map from","name":"Object","type":"objectList"}],"objectGroups":[]},{"description":"Apply an ambient occlusion (AO) map to a 3D object. AO maps multiply lighting and require a second UV set (uv2) on the model for accurate results.","fullName":"Set AO Map","functionType":"Action","name":"SetAOMap","sentence":"Set AO map of _PARAM1_ to _PARAM2_ with scale _PARAM3_ and intensity _PARAM4_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","var imageName = eventsFunctionContext.getArgument(\"AOMap\");","var scaleVal = Number(eventsFunctionContext.getArgument(\"Scale\"));","var intensityVal = Number(eventsFunctionContext.getArgument(\"Intensity\"));","","if (isNaN(scaleVal) || scaleVal <= 0) scaleVal = 1;","if (isNaN(intensityVal)) intensityVal = 1;","","var game = runtimeScene.getGame();","var imageUrl = imageName;","try {","    var res = game.getResourcesManager();","    if (res && res.getResource(imageName)) {","        imageUrl = res.getResource(imageName).getFile();","    }","} catch(e) {}","","var capturedScale = scaleVal;","var capturedIntensity = intensityVal;","var capturedObjs = objs.slice();","var loader = new THREE.TextureLoader();","loader.load(imageUrl, function(tex) {","    tex.wrapS = THREE.RepeatWrapping;","    tex.wrapT = THREE.RepeatWrapping;","    if (typeof tex.encoding !== 'undefined') {","        tex.encoding = THREE.LinearEncoding;","    } else if (typeof tex.colorSpace !== 'undefined') {","        tex.colorSpace = THREE.NoColorSpace;","    }","    ","    for (var i = 0; i < capturedObjs.length; i++) {","        if (!capturedObjs[i].get3DRendererObject) continue;","        var root = capturedObjs[i].get3DRendererObject();","        if (!root) continue;","        ","        var objType = capturedObjs[i].getType ? capturedObjs[i].getType() : '';","        var isGLB = objType.indexOf('Model3D') !== -1 || objType.indexOf('Scene3D::Model3DObject') !== -1;","        ","        root.traverse(function(c) {","            if (!c.isMesh || !c.material) return;","            ","            var materials = Array.isArray(c.material) ? c.material : [c.material];","            var newMaterials = [];","            ","            for (var m = 0; m < materials.length; m++) {","                var mat = materials[m];","                ","                if (mat.isMeshBasicMaterial) {","                    mat = new THREE.MeshStandardMaterial({","                        color: mat.color ? mat.color.clone() : new THREE.Color(0xffffff),","                        map: mat.map || null,","                        transparent: mat.transparent,","                        opacity: mat.opacity !== undefined ? mat.opacity : 1,","                        side: mat.side !== undefined ? mat.side : THREE.FrontSide,","                        metalness: 0.0,","                        roughness: 0.7,","                        skinning: mat.skinning === true,","                        morphTargets: mat.morphTargets === true,","                        morphNormals: mat.morphNormals === true","                    });","                } else if (!c.userData._aoMapApplied) {","                    mat = mat.clone();","                }","                ","                if (mat.isMeshStandardMaterial || mat.isMeshPhongMaterial || mat.isMeshPhysicalMaterial) {","                    var clonedTex = tex.clone();","                    clonedTex.wrapS = THREE.RepeatWrapping;","                    clonedTex.wrapT = THREE.RepeatWrapping;","                    if (typeof clonedTex.encoding !== 'undefined') {","                        clonedTex.encoding = THREE.LinearEncoding;","                    } else if (typeof clonedTex.colorSpace !== 'undefined') {","                        clonedTex.colorSpace = THREE.NoColorSpace;","                    }","                    clonedTex.flipY = !isGLB;","                    clonedTex.repeat.set(capturedScale, capturedScale);","                    clonedTex.needsUpdate = true;","                    ","                    if (c.geometry && c.geometry.attributes.uv && !c.geometry.attributes.uv2) {","                        c.geometry.setAttribute('uv2', c.geometry.attributes.uv.clone());","                    }","                    ","                    mat.aoMap = clonedTex;","                    mat.aoMapIntensity = capturedIntensity;","                    mat.needsUpdate = true;","                }","                ","                newMaterials.push(mat);","            }","            ","            c.material = Array.isArray(c.material) ? newMaterials : newMaterials[0];","            c.userData._aoMapApplied = true;","        });","    }","});"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to apply the AO map to","name":"Object","type":"objectList"},{"description":"The AO map image (grayscale). PNG or WebP recommended.","name":"AOMap","type":"imageResource"},{"description":"How many times the texture repeats. 1 = no repeat, 2 = repeats 2x, 0.5 = stretched","name":"Scale","type":"expression"},{"description":"Intensity/strength of the AO map effect. 1 = normal, 0 = no effect, 2 = double strength","name":"Intensity","type":"expression"}],"objectGroups":[]},{"description":"Remove AO map from a 3D object.","fullName":"Remove AO Map","functionType":"Action","name":"RemoveAOMap","sentence":"Remove AO map from _PARAM1_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","for (var i = 0; i < objs.length; i++) {","    if (!objs[i].get3DRendererObject) continue;","    var root = objs[i].get3DRendererObject();","    if (!root) continue;","    root.traverse(function(c) {","        if (!c.isMesh || !c.material) return;","        var materials = Array.isArray(c.material) ? c.material : [c.material];","        for (var m = 0; m < materials.length; m++) {","            if (materials[m] && materials[m].aoMap) {","                materials[m].aoMap = null;","                materials[m].needsUpdate = true;","            }","        }","    });","}"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to remove AO map from","name":"Object","type":"objectList"}],"objectGroups":[]},{"description":"Apply a displacement/height map to add real geometry variation when supported by the mesh. Many models require additional vertex density for visible displacement.","fullName":"Set Height Map","functionType":"Action","name":"SetHeightMap","sentence":"Set height map of _PARAM1_ to _PARAM2_ with scale _PARAM3_ and intensity _PARAM4_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","var imageName = eventsFunctionContext.getArgument(\"HeightMap\");","var scaleVal = Number(eventsFunctionContext.getArgument(\"Scale\"));","var intensityVal = Number(eventsFunctionContext.getArgument(\"Intensity\"));","","if (isNaN(scaleVal) || scaleVal <= 0) scaleVal = 1;","if (isNaN(intensityVal)) intensityVal = 0.1;","","var game = runtimeScene.getGame();","var imageUrl = imageName;","try {","    var res = game.getResourcesManager();","    if (res && res.getResource(imageName)) {","        imageUrl = res.getResource(imageName).getFile();","    }","} catch(e) {}","","var capturedScale = scaleVal;","var capturedIntensity = intensityVal;","var capturedObjs = objs.slice();","var loader = new THREE.TextureLoader();","loader.load(imageUrl, function(tex) {","    tex.wrapS = THREE.RepeatWrapping;","    tex.wrapT = THREE.RepeatWrapping;","    if (typeof tex.encoding !== 'undefined') {","        tex.encoding = THREE.sRGBEncoding;","    } else if (typeof tex.colorSpace !== 'undefined') {","        tex.colorSpace = THREE.SRGBColorSpace;","    }","    ","    for (var i = 0; i < capturedObjs.length; i++) {","        if (!capturedObjs[i].get3DRendererObject) continue;","        var root = capturedObjs[i].get3DRendererObject();","        if (!root) continue;","        ","        var objType = capturedObjs[i].getType ? capturedObjs[i].getType() : '';","        var isGLB = objType.indexOf('Model3D') !== -1 || objType.indexOf('Scene3D::Model3DObject') !== -1;","        ","        root.traverse(function(c) {","            if (!c.isMesh || !c.material) return;","            ","            var materials = Array.isArray(c.material) ? c.material : [c.material];","            var newMaterials = [];","            ","            for (var m = 0; m < materials.length; m++) {","                var mat = materials[m];","                ","                if (mat.isMeshBasicMaterial) {","                    mat = new THREE.MeshStandardMaterial({","                        color: mat.color ? mat.color.clone() : new THREE.Color(0xffffff),","                        map: mat.map || null,","                        transparent: mat.transparent,","                        opacity: mat.opacity !== undefined ? mat.opacity : 1,","                        side: mat.side !== undefined ? mat.side : THREE.FrontSide,","                        metalness: 0.0,","                        roughness: 0.7,","                        skinning: mat.skinning === true,","                        morphTargets: mat.morphTargets === true,","                        morphNormals: mat.morphNormals === true","                    });","                } else if (!c.userData._heightMapApplied) {","                    mat = mat.clone();","                }","                ","                if (mat.isMeshStandardMaterial || mat.isMeshPhongMaterial || mat.isMeshPhysicalMaterial) {","                    var clonedTex = tex.clone();","                    clonedTex.wrapS = THREE.RepeatWrapping;","                    clonedTex.wrapT = THREE.RepeatWrapping;","                    if (typeof clonedTex.encoding !== 'undefined') {","                        clonedTex.encoding = THREE.LinearEncoding;","                    } else if (typeof clonedTex.colorSpace !== 'undefined') {","                        clonedTex.colorSpace = THREE.NoColorSpace;","                    }","                    clonedTex.flipY = !isGLB;","                    clonedTex.repeat.set(capturedScale, capturedScale);","                    clonedTex.needsUpdate = true;","                    ","                    mat.displacementMap = clonedTex;","                    mat.displacementScale = capturedIntensity;","                    mat.displacementBias = -capturedIntensity * 0.25;","                    mat.needsUpdate = true;","                }","                ","                newMaterials.push(mat);","            }","            ","            c.material = Array.isArray(c.material) ? newMaterials : newMaterials[0];","            c.userData._heightMapApplied = true;","        });","    }","});"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to apply the height map to","name":"Object","type":"objectList"},{"description":"The height/displacement map image (grayscale). PNG or WebP recommended.","name":"HeightMap","type":"imageResource"},{"description":"How many times the texture repeats. 1 = no repeat, 2 = repeats 2x, 0.5 = stretched","name":"Scale","type":"expression"},{"description":"Intensity/strength of the displacement. Small values like 0.1 often work best.","name":"Intensity","type":"expression"}],"objectGroups":[]},{"description":"Remove height/displacement map from a 3D object.","fullName":"Remove Height Map","functionType":"Action","name":"RemoveHeightMap","sentence":"Remove height map from _PARAM1_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","for (var i = 0; i < objs.length; i++) {","    if (!objs[i].get3DRendererObject) continue;","    var root = objs[i].get3DRendererObject();","    if (!root) continue;","    root.traverse(function(c) {","        if (!c.isMesh || !c.material) return;","        var materials = Array.isArray(c.material) ? c.material : [c.material];","        for (var m = 0; m < materials.length; m++) {","            if (materials[m] && materials[m].displacementMap) {","                materials[m].displacementMap = null;","                materials[m].displacementScale = 0;","                materials[m].displacementBias = 0;","                materials[m].needsUpdate = true;","            }","        }","    });","}"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to remove height map from","name":"Object","type":"objectList"}],"objectGroups":[]},{"description":"Apply an emissive map (glow) to a 3D object. The emissive color/intensity controls how bright the emissive map appears.","fullName":"Set Emissive Map","functionType":"Action","name":"SetEmissiveMap","sentence":"Set emissive map of _PARAM1_ to _PARAM2_ with scale _PARAM3_ and intensity _PARAM4_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","var imageName = eventsFunctionContext.getArgument(\"EmissiveMap\");","var scaleVal = Number(eventsFunctionContext.getArgument(\"Scale\"));","var intensityVal = Number(eventsFunctionContext.getArgument(\"Intensity\"));","","if (isNaN(scaleVal) || scaleVal <= 0) scaleVal = 1;","if (isNaN(intensityVal)) intensityVal = 1;","","var game = runtimeScene.getGame();","var imageUrl = imageName;","try {","    var res = game.getResourcesManager();","    if (res && res.getResource(imageName)) {","        imageUrl = res.getResource(imageName).getFile();","    }","} catch(e) {}","","var capturedScale = scaleVal;","var capturedIntensity = intensityVal;","var capturedObjs = objs.slice();","var loader = new THREE.TextureLoader();","loader.load(imageUrl, function(tex) {","    tex.wrapS = THREE.RepeatWrapping;","    tex.wrapT = THREE.RepeatWrapping;","    tex.colorSpace = THREE.NoColorSpace;","    ","    for (var i = 0; i < capturedObjs.length; i++) {","        if (!capturedObjs[i].get3DRendererObject) continue;","        var root = capturedObjs[i].get3DRendererObject();","        if (!root) continue;","        ","        var objType = capturedObjs[i].getType ? capturedObjs[i].getType() : '';","        var isGLB = objType.indexOf('Model3D') !== -1 || objType.indexOf('Scene3D::Model3DObject') !== -1;","        ","        root.traverse(function(c) {","            if (!c.isMesh || !c.material) return;","            ","            var materials = Array.isArray(c.material) ? c.material : [c.material];","            var newMaterials = [];","            ","            for (var m = 0; m < materials.length; m++) {","                var mat = materials[m];","                ","                if (mat.isMeshBasicMaterial) {","                    mat = new THREE.MeshStandardMaterial({","                        color: mat.color ? mat.color.clone() : new THREE.Color(0xffffff),","                        map: mat.map || null,","                        transparent: mat.transparent,","                        opacity: mat.opacity !== undefined ? mat.opacity : 1,","                        side: mat.side !== undefined ? mat.side : THREE.FrontSide,","                        metalness: 0.0,","                        roughness: 0.7","                    });","                } else if (!c.userData._emissiveMapApplied) {","                    mat = mat.clone();","                }","                ","                if (mat.isMeshStandardMaterial || mat.isMeshPhongMaterial || mat.isMeshPhysicalMaterial) {","                    var clonedTex = tex.clone();","                    clonedTex.wrapS = THREE.RepeatWrapping;","                    clonedTex.wrapT = THREE.RepeatWrapping;","                    if (typeof clonedTex.encoding !== 'undefined') {","                        clonedTex.encoding = THREE.sRGBEncoding;","                    } else if (typeof clonedTex.colorSpace !== 'undefined') {","                        clonedTex.colorSpace = THREE.SRGBColorSpace;","                    }","                    clonedTex.flipY = !isGLB;","                    clonedTex.repeat.set(capturedScale, capturedScale);","                    clonedTex.needsUpdate = true;","                    ","                    mat.emissive = new THREE.Color(0xffffff);","                    mat.emissiveMap = clonedTex;","                    mat.emissiveIntensity = capturedIntensity;","                    mat.needsUpdate = true;","                }","                ","                newMaterials.push(mat);","            }","            ","            c.material = Array.isArray(c.material) ? newMaterials : newMaterials[0];","            c.userData._emissiveMapApplied = true;","        });","    }","});"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to apply the emissive map to","name":"Object","type":"objectList"},{"description":"The emissive map image (colors represent glowing areas). PNG or WebP recommended.","name":"EmissiveMap","type":"imageResource"},{"description":"How many times the texture repeats. 1 = no repeat, 2 = repeats 2x, 0.5 = stretched","name":"Scale","type":"expression"},{"description":"Intensity/strength of the emissive effect. 1 = normal, 2 = brighter","name":"Intensity","type":"expression"}],"objectGroups":[]},{"description":"Remove emissive map from a 3D object.","fullName":"Remove Emissive Map","functionType":"Action","name":"RemoveEmissiveMap","sentence":"Remove emissive map from _PARAM1_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["var objs = eventsFunctionContext.getObjects(\"Object\");","for (var i = 0; i < objs.length; i++) {","    if (!objs[i].get3DRendererObject) continue;","    var root = objs[i].get3DRendererObject();","    if (!root) continue;","    root.traverse(function(c) {","        if (!c.isMesh || !c.material) return;","        var materials = Array.isArray(c.material) ? c.material : [c.material];","        for (var m = 0; m < materials.length; m++) {","            if (materials[m] && materials[m].emissiveMap) {","                materials[m].emissiveMap = null;","                materials[m].emissiveIntensity = 1;","                materials[m].needsUpdate = true;","            }","        }","    });","}"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}],"parameters":[{"description":"The 3D object to remove emissive map from","name":"Object","type":"objectList"}],"objectGroups":[]},{"description":"Apply an albedo/diffuse map (base color texture) to a 3D object. This replaces or adds the main color texture.","fullName":"Set Albedo Map","functionType":"Action","name":"SetAlbedoMap","sentence":"Set albedo map of _PARAM1_ to _PARAM2_ with scale _PARAM3_","events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["va